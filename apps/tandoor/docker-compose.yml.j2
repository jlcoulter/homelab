services:
  db:
    image: postgres:14-alpine
    environment:
      POSTGRES_DB: "{{ tandoor_db_name | default('tandoor') }}"
      POSTGRES_USER: "{{ tandoor_db_user | default('tandoor') }}"
      POSTGRES_PASSWORD: "{{ tandoor_db_password | default('changeme') }}"
    volumes:
      - "{{ tandoor_db_data_path | default('/var/lib/tandoor/postgres') }}:/var/lib/postgresql/data"
    networks:
      - tandoor-network
    deploy:
      mode: replicated
      replicas: 1
      restart_policy:
        condition: on-failure
        delay: 5s
        max_attempts: 3
        window: 120s

  redis:
    image: redis:7-alpine
    command: ["redis-server", "--save", "", "--appendonly", "no"]
    networks:
      - tandoor-network
    deploy:
      mode: replicated
      replicas: 1
      restart_policy:
        condition: on-failure
        delay: 5s
        max_attempts: 3
        window: 120s

  tandoor:
    image: TandoorRecipes/tandoor:latest
    depends_on:
      - db
      - redis
    environment:
      DATABASE_URL: "postgres://{{ tandoor_db_user | default('tandoor') }}:{{ tandoor_db_password | default('changeme') }}@db:5432/{{ tandoor_db_name | default('tandoor') }}"
      REDIS_URL: "redis://redis:6379/0"
      TZ: "{{ tandoor_tz | default('UTC') }}"
    ports:
      - target: 80
        published: {{ tandoor_port | default('8080') }}
        protocol: tcp
        mode: ingress
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.tandoor.rule=Host(`{{ app_metadata['tandoor'].hostname }}`)"
      - "traefik.http.routers.tandoor.entrypoints=websecure"
      - "traefik.http.routers.tandoor.tls=true"
      - "traefik.http.services.tandoor.loadbalancer.server.port=80"
      - "homepage.group=Productivity"
      - "homepage.name=Tandoor Recipes"
      - "homepage.icon=tandoor.png"
      - "homepage.href=https://{{ app_metadata['tandoor'].hostname }}"
      - "homepage.description=Recipe management and meal planning"
    volumes:
      - "{{ tandoor_media_path | default('./media') }}:/opt/tandoor/media"
      - "{{ tandoor_static_path | default('./static') }}:/opt/tandoor/static"
    networks:
      - tandoor-network
      - traefik-public
    deploy:
      mode: replicated
      replicas: 1
      restart_policy:
        condition: on-failure
        delay: 5s
        max_attempts: 3
        window: 120s

networks:
  tandoor-network:
    external: false
  traefik-public:
    external: true
