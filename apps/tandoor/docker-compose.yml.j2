services:
  db:
    image: postgres:14-alpine
    restart: unless-stopped
    environment:
      POSTGRES_DB: "{{ tandoor_db_name | default('tandoor') }}"
      POSTGRES_USER: "{{ tandoor_db_user | default('tandoor') }}"
      POSTGRES_PASSWORD: "{{ tandoor_db_password | default('changeme') }}"
    volumes:
      - "{{ tandoor_db_data_path | default('/var/lib/tandoor/postgres') }}:/var/lib/postgresql/data"
    networks:
      - tandoor-network

  redis:
    image: redis:7-alpine
    restart: unless-stopped
    command: ["redis-server", "--save", "", "--appendonly", "no"]
    networks:
      - tandoor-network

  tandoor:
    image: TandoorRecipes/tandoor:latest
    restart: unless-stopped
    depends_on:
      - db
      - redis
    environment:
      DATABASE_URL: "postgres://{{ tandoor_db_user | default('tandoor') }}:{{ tandoor_db_password | default('changeme') }}@db:5432/{{ tandoor_db_name | default('tandoor') }}"
      REDIS_URL: "redis://redis:6379/0"
      TZ: "{{ tandoor_tz | default('UTC') }}"
    ports:
      - "{{ tandoor_port | default('8080') }}:80"
    volumes:
      - "{{ tandoor_media_path | default('./media') }}:/opt/tandoor/media"
      - "{{ tandoor_static_path | default('./static') }}:/opt/tandoor/static"
    networks:
      - tandoor-network

networks:
  tandoor-network:
    driver: bridge
